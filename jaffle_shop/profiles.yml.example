# Copy this file to profiles.yml and source your .env before running dbt.
# profiles.yml is gitignored. Never commit a filled-in copy.
#
# Usage:
#   cp .env.template .env            # then edit .env with your values
#   cp profiles.yml.example profiles.yml
#   set -a && source .env && set +a  # export env vars to the shell
#   dbt deps && dbt seed && dbt run && dbt test

jaffle_shop:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST') | replace('https://', '') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      catalog: "{{ env_var('DATABRICKS_CATALOG') }}"
      schema: "{{ env_var('DATABRICKS_SCHEMA') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4
